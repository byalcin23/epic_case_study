    {
      "name": "Find pets by invalid status - negative scenario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "//For the invalid status scenario, the public Petstore API returns 200 with an empty JSON response instead of a strict 400 error. Because of that, the test accepts both 200 and 400 as handled responses, but it would fail on unexpected server errors like 500.",
              "pm.test('NEGATIVE CHECK: Invalid status request', function () {",
              "    pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "",
              "",
              "pm.test('NEGATIVE CHECK: Response is valid JSON', ",
              "    function () {",
              "    pm.response.to.be.json;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
