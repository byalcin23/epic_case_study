    {
      "name": "Find pets by status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array of pets', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array'); // expect response as array",
              "    json.slice(0, 10).forEach(function (pet) {  //check firts 10 pet have id and status",
              "        pm.expect(pet).to.have.property('id');",
              "        pm.expect(pet).to.have.property('status');",
              "    });",
              "});"
            ],
