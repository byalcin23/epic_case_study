  "item": [
    {
      "name": "Add pet",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const petId = Number(`77${Date.now().toString().slice(-10)}`);",
              "pm.collectionVariables.set('petId', petId);",
              "pm.collectionVariables.set('petName', `EpicPet-${petId}`);",
              "pm.collectionVariables.set('tagName', 'epic-case-study');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains created pet data', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('object');",
              "    pm.expect(Number(json.id)).to.eql(Number(pm.collectionVariables.get('petId')));",
              "    pm.expect(json.name).to.eql(pm.collectionVariables.get('petName'));",
              "    pm.expect(json.status).to.eql('available');",
              "    pm.expect(json.photoUrls).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{petId}},\n  \"category\": {\n    \"id\": 100,\n    \"name\": \"case-study\"\n  },\n  \"name\": \"{{petName}}\",\n  \"photoUrls\": [\n    \"https://example.com/pet.jpg\"\n  ],\n  \"tags\": [\n    {\n      \"id\": 100,\n      \"name\": \"{{tagName}}\"\n    }\n  ],\n  \"status\": \"available\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pet",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet"
          ]
        }
      },
      "response": []
    },
